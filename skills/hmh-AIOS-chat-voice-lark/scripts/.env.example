# ── TÔM Voice (.env mẫu) — copy thành .env rồi điền ──────────────────────────

# (BẮT BUỘC) App Lark — Developer Console > Credentials & Basic Info
APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# lark (open.larksuite.com) | feishu (open.feishu.cn)
LARK_DOMAIN=lark

# (BẮT BUỘC) Chủ + nhóm điều khiển — lấy bằng: node whoami.mjs
OWNER_OPEN_ID=ou_xxxxxxxxxxxxxxxx
CONTROL_CHAT_ID=oc_xxxxxxxxxxxxxxxx

# ── Claude headless ──────────────────────────────────────────────────────────
# Để trống = start-mac.sh tự tìm bản Claude desktop mới nhất
CLAUDE_BIN=
CLAUDE_MODEL=haiku
# ⚠️ bypassPermissions = chạy thẳng lệnh KHÔNG hỏi. Chỉ trên máy của chủ.
# An toàn hơn: default | acceptEdits
PERMISSION_MODE=default
# Thư mục "bộ não" Claude làm việc (vault/wiki/output…)
BRAIN_ROOT=/Users/ban/duong-dan/vault
KEEP_SESSION=true
CLAUDE_TIMEOUT_MS=1500000

# ── Giọng nói ────────────────────────────────────────────────────────────────
VOICE_DEFAULT=on            # on | off (mặc định trả lời bằng giọng)
MAX_VOICE_WORDS=70          # rút gọn câu trả lời thoại
WHISPER_URL=http://127.0.0.1:8765
WHISPER_PORT=8765
WHISPER_MODEL=small         # tiny | base | small | medium (máy yếu dùng small/base)
WHISPER_DEVICE=cpu          # Apple Silicon: cpu
WHISPER_COMPUTE=int8

# Để trống = tự dùng imageio-ffmpeg trong venv
FFMPEG_BIN=

# TTS: auto | gtts (miễn phí, cần net) | vbee (cần key) | say (offline mac)
TTS_ENGINE=gtts
VOICE_CODE=
# Vbee (tuỳ chọn) — vbee.vn > API
VBEE_API=
VBEE_APP_ID=
# Giọng macOS 'say' nếu dùng TTS_ENGINE=say (cần cài giọng tiếng Việt trong System Settings)
MAC_SAY_VOICE=
