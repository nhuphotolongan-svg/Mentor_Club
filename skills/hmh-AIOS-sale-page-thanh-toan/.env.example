# Biến môi trường của hệ thống sale page — KHÔNG commit, KHÔNG lưu vào memory.
# Production: nạp bằng `wrangler pages secret put <KEY> --project-name <slug>`.
# Local dev: copy thành `.dev.vars` trong thư mục project rồi `wrangler pages dev .`.

# --- Lark Base (bắt buộc) ---
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
LARK_BASE_TOKEN=xxxxxxxxxxxxxxxxxxxxx        # từ URL larksuite.com/base/<token>
LARK_TABLE_ID=tblxxxxxxxxxxxx                # bảng Leads
LARK_TEMPLATE_TABLE_ID=tblxxxxxxxxxxxx       # tuỳ chọn — bảng Email Templates

# --- Sepay (bắt buộc để nhận tiền) ---
SEPAY_API_KEY=x3sepay_xxxxxxxxxxxxxxxx       # scaffold tự sinh; dán cùng giá trị vào webhook Sepay

# --- Email qua Lark SMTP (bắt buộc nếu muốn gửi mail) ---
SMTP_USER=mentor@domain.net
SMTP_PASS=xxxxxxxxxxxx                        # Application Password (Lark Settings → Security)
# SMTP_HOST=smtp.larksuite.com               # mặc định
# SMTP_PORT=465                              # mặc định
# SMTP_FROM=mentor@domain.net                # mặc định = SMTP_USER

# --- Smax.ai → Zalo (tuỳ chọn) ---
SMAX_TRIGGER_URL=https://api.smax.ai/public/bizs/<slug>/triggers/<id>
SMAX_TOKEN=xxxxxxxxxxxx
SMAX_CUSTOMER_PID=zlwxxxxxxx
SMAX_PAGE_ID=xxxxxxxxxx

# --- Thương hiệu (đã có trong wrangler.toml [vars], có thể override) ---
# BRAND_NAME=Khóa X3
# BRAND_COLOR=#E11D48
# EMAIL_TEMPLATE_KEY=x3_registration
