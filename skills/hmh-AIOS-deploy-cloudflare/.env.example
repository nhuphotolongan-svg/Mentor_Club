# Cloudflare — copy file này thành .env và điền giá trị THẬT. KHÔNG commit .env, KHÔNG gửi cho khách.

# Token quyền: Account · Cloudflare Pages · Edit  +  Zone · DNS · Edit
# Tạo tại: Dashboard → My Profile → API Tokens → Create Token
CF_API_TOKEN=

# Lấy bằng:  npx wrangler whoami
CF_ACCOUNT_ID=

# (Tuỳ chọn) zone id của tên miền — nếu để trống, add-domain.mjs tự dò theo tên domain
CF_ZONE_ID=
